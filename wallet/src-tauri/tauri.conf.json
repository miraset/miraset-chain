{
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build:ui",
    "devPath": "http://localhost:3000",
    "distDir": "../out"
  },
  "package": {
    "productName": "wallet-miraset",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "windows": [
      {
        "title": "MIRASET Wallet",
        "width": 1100,
        "height": 720,
        "resizable": true
      }
    ],
    "bundle": {
      "active": false,
      "identifier": "com.miraset.wallet"
    }
  }
}
